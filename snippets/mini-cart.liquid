{% comment %}
  Mini Cart Drawer
  - Opens when product is added to cart
  - Shows cart items with quantity controls
  - Free shipping progress bar
  - Product recommendations
{% endcomment %}

<div class="mini-cart-overlay" id="MiniCartOverlay"></div>

<div class="mini-cart" id="MiniCart" aria-hidden="true">
  <!-- Header -->
  <div class="mini-cart__header">
    <h2 class="mini-cart__title">
      Cart
      <span class="mini-cart__count" id="MiniCartCount">{{ cart.item_count }}</span>
    </h2>
    <button type="button" class="mini-cart__close" id="MiniCartClose" aria-label="Close cart">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Free Shipping Progress -->
  {%- assign free_shipping_threshold = 9900 -%}
  {%- assign cart_total = cart.total_price -%}
  {%- assign remaining = free_shipping_threshold | minus: cart_total -%}
  {%- assign progress_percent = cart_total | times: 100 | divided_by: free_shipping_threshold -%}
  {%- if progress_percent > 100 %}{% assign progress_percent = 100 %}{% endif -%}
  
  <div class="mini-cart__shipping" id="MiniCartShipping">
    {%- if remaining <= 0 -%}
      <p class="mini-cart__shipping-text mini-cart__shipping-text--success">
        Congratulations! You qualified for <strong>Free Ground Shipping</strong>.
      </p>
    {%- else -%}
      <p class="mini-cart__shipping-text">
        Add <strong>{{ remaining | money }}</strong> more for <strong>Free Ground Shipping</strong>.
      </p>
    {%- endif -%}
    <div class="mini-cart__shipping-bar">
      <div class="mini-cart__shipping-progress" style="width: {{ progress_percent }}%;"></div>
    </div>
  </div>

  <!-- Cart Items -->
  <div class="mini-cart__items" id="MiniCartItems">
    {%- if cart.item_count > 0 -%}
      {%- for item in cart.items -%}
        <div class="mini-cart__item" data-line-key="{{ item.key }}">
          <a href="{{ item.url }}" class="mini-cart__item-image">
            {%- if item.image -%}
              <img src="{{ item.image | image_url: width: 120 }}" alt="{{ item.title | escape }}" width="60" height="75" loading="lazy">
            {%- else -%}
              <div class="mini-cart__item-placeholder"></div>
            {%- endif -%}
          </a>
          
          <div class="mini-cart__item-details">
            <a href="{{ item.url }}" class="mini-cart__item-title">{{ item.product.title }}</a>
            
            {%- unless item.product.has_only_default_variant -%}
              <p class="mini-cart__item-variant">
                {%- for option in item.options_with_values -%}
                  {{ option.name }}: {{ option.value }}{% unless forloop.last %}, {% endunless %}
                {%- endfor -%}
              </p>
            {%- endunless -%}
            
            <div class="mini-cart__item-quantity">
              <button type="button" class="mini-cart__qty-btn" data-action="decrease" data-key="{{ item.key }}" aria-label="Decrease quantity">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </button>
              <span class="mini-cart__qty-value">{{ item.quantity }}</span>
              <button type="button" class="mini-cart__qty-btn" data-action="increase" data-key="{{ item.key }}" aria-label="Increase quantity">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="12" y1="5" x2="12" y2="19"></line>
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
              </button>
            </div>
          </div>
          
          <div class="mini-cart__item-right">
            <button type="button" class="mini-cart__item-remove" data-action="remove" data-key="{{ item.key }}" aria-label="Remove item">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="3 6 5 6 21 6"></polyline>
                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
              </svg>
            </button>
            <span class="mini-cart__item-price">{{ item.final_line_price | money }}</span>
          </div>
        </div>
      {%- endfor -%}
    {%- else -%}
      <div class="mini-cart__empty">
        <p>Your cart is empty</p>
        <a href="{{ routes.all_products_collection_url }}" class="mini-cart__continue">Continue Shopping</a>
      </div>
    {%- endif -%}
  </div>

  <!-- Footer -->
  <div class="mini-cart__footer" id="MiniCartFooter" {% if cart.item_count == 0 %}style="display: none;"{% endif %}>
    <div class="mini-cart__subtotal">
      <span>Subtotal</span>
      <span class="mini-cart__subtotal-price" id="MiniCartSubtotal">{{ cart.total_price | money }}</span>
    </div>
    <p class="mini-cart__note">Tax and shipping calculated at checkout.</p>
    <a href="{{ routes.cart_url }}" class="mini-cart__checkout-btn">View Cart &amp; Begin Checkout</a>
  </div>
</div>

<style>
/* Mini Cart Overlay */
.mini-cart-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.mini-cart-overlay.active {
  opacity: 1;
  visibility: visible;
}

/* Mini Cart Drawer */
.mini-cart {
  position: fixed;
  top: 0;
  right: 0;
  width: 100%;
  max-width: 420px;
  height: 100%;
  background: #fff;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s ease-in-out;
  box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);
}

.mini-cart.active {
  transform: translateX(0);
}

/* Header */
.mini-cart__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px 20px;
  border-bottom: 1px solid #e5e5e5;
  flex-shrink: 0;
}

.mini-cart__title {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 18px;
  font-weight: 700;
  margin: 0;
  color: #1a1a1a;
}

.mini-cart__count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 22px;
  height: 22px;
  padding: 0 6px;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  background: #e85c2b;
  border-radius: 11px;
}

.mini-cart__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: none;
  border: none;
  cursor: pointer;
  color: #666;
  transition: color 0.15s;
}

.mini-cart__close:hover {
  color: #1a1a1a;
}

/* Free Shipping */
.mini-cart__shipping {
  padding: 16px 20px;
  background: #f8f8f8;
  flex-shrink: 0;
}

.mini-cart__shipping-text {
  font-size: 13px;
  color: #333;
  margin: 0 0 10px 0;
  text-align: center;
}

.mini-cart__shipping-text--success {
  color: #2e7d32;
}

.mini-cart__shipping-bar {
  height: 6px;
  background: #e0e0e0;
  border-radius: 3px;
  overflow: hidden;
}

.mini-cart__shipping-progress {
  height: 100%;
  background: #4caf50;
  border-radius: 3px;
  transition: width 0.3s;
}

/* Cart Items */
.mini-cart__items {
  flex: 1;
  overflow-y: auto;
  padding: 0;
}

.mini-cart__item {
  display: flex;
  gap: 12px;
  padding: 16px 20px;
  border-bottom: 1px solid #f0f0f0;
}

.mini-cart__item-image {
  flex-shrink: 0;
  width: 70px;
  height: 85px;
  background: #f5f5f5;
  border-radius: 4px;
  overflow: hidden;
}

.mini-cart__item-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.mini-cart__item-placeholder {
  width: 100%;
  height: 100%;
  background: #e0e0e0;
}

.mini-cart__item-details {
  flex: 1;
  min-width: 0;
}

.mini-cart__item-title {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #1a1a1a;
  text-decoration: none;
  line-height: 1.4;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.mini-cart__item-title:hover {
  color: #e85c2b;
}

.mini-cart__item-variant {
  font-size: 12px;
  color: #666;
  margin: 0 0 10px 0;
}

.mini-cart__item-quantity {
  display: inline-flex;
  align-items: center;
  border: 1px solid #ddd;
  border-radius: 4px;
  overflow: hidden;
}

.mini-cart__qty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: #f5f5f5;
  border: none;
  cursor: pointer;
  color: #333;
  transition: background 0.15s;
}

.mini-cart__qty-btn:hover {
  background: #e5e5e5;
}

.mini-cart__qty-value {
  width: 32px;
  text-align: center;
  font-size: 13px;
  font-weight: 600;
}

.mini-cart__item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
}

.mini-cart__item-remove {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28px;
  height: 28px;
  background: none;
  border: none;
  cursor: pointer;
  color: #999;
  transition: color 0.15s;
}

.mini-cart__item-remove:hover {
  color: #c41e3a;
}

.mini-cart__item-price {
  font-size: 14px;
  font-weight: 700;
  color: #1a1a1a;
}

/* Empty State */
.mini-cart__empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
  text-align: center;
}

.mini-cart__empty p {
  font-size: 16px;
  color: #666;
  margin: 0 0 20px 0;
}

.mini-cart__continue {
  display: inline-block;
  padding: 12px 24px;
  font-size: 14px;
  font-weight: 600;
  color: #fff;
  background: #1a1a1a;
  text-decoration: none;
  border-radius: 4px;
  transition: background 0.15s;
}

.mini-cart__continue:hover {
  background: #333;
}

/* Footer */
.mini-cart__footer {
  padding: 20px;
  border-top: 1px solid #e5e5e5;
  background: #fff;
  flex-shrink: 0;
}

.mini-cart__subtotal {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.mini-cart__subtotal span:first-child {
  font-size: 14px;
  color: #333;
}

.mini-cart__subtotal-price {
  font-size: 18px;
  font-weight: 700;
  color: #1a1a1a;
}

.mini-cart__note {
  font-size: 12px;
  color: #666;
  margin: 0 0 16px 0;
}

.mini-cart__checkout-btn {
  display: block;
  width: 100%;
  padding: 14px 20px;
  font-size: 14px;
  font-weight: 700;
  color: #fff;
  background: #e85c2b;
  text-align: center;
  text-decoration: none;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  transition: background 0.15s;
}

.mini-cart__checkout-btn:hover {
  background: #d14d1f;
}

/* Body lock when cart is open */
body.mini-cart-open {
  overflow: hidden;
}
</style>

<script>
(function() {
  const miniCart = document.getElementById('MiniCart');
  const overlay = document.getElementById('MiniCartOverlay');
  const closeBtn = document.getElementById('MiniCartClose');
  const cartToggles = document.querySelectorAll('[data-cart-toggle]');

  // Open/Close functions
  function openMiniCart() {
    miniCart.classList.add('active');
    overlay.classList.add('active');
    miniCart.setAttribute('aria-hidden', 'false');
    document.body.classList.add('mini-cart-open');
  }

  function closeMiniCart() {
    miniCart.classList.remove('active');
    overlay.classList.remove('active');
    miniCart.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('mini-cart-open');
  }

  // Event listeners
  cartToggles.forEach(btn => btn.addEventListener('click', openMiniCart));
  closeBtn.addEventListener('click', closeMiniCart);
  overlay.addEventListener('click', closeMiniCart);

  // Close on ESC
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && miniCart.classList.contains('active')) {
      closeMiniCart();
    }
  });

  // Quantity & Remove actions
  document.getElementById('MiniCartItems').addEventListener('click', async (e) => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;

    const action = btn.dataset.action;
    const key = btn.dataset.key;
    const item = btn.closest('.mini-cart__item');
    const qtyEl = item.querySelector('.mini-cart__qty-value');
    let quantity = parseInt(qtyEl.textContent, 10);

    if (action === 'increase') {
      quantity++;
    } else if (action === 'decrease') {
      quantity = Math.max(0, quantity - 1);
    } else if (action === 'remove') {
      quantity = 0;
    }

    // Update cart via AJAX
    try {
      const res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: quantity })
      });
      const cart = await res.json();
      
      if (quantity === 0) {
        item.remove();
      } else {
        qtyEl.textContent = quantity;
      }

      updateCartUI(cart);
    } catch (err) {
      console.error('Cart update error:', err);
    }
  });

  // Update cart UI after changes
  function updateCartUI(cart) {
    // Update count badges
    document.querySelectorAll('.mini-cart__count, .cart-count').forEach(el => {
      el.textContent = cart.item_count;
      el.style.display = cart.item_count > 0 ? '' : 'none';
    });

    // Update subtotal
    const subtotal = document.getElementById('MiniCartSubtotal');
    if (subtotal) {
      subtotal.textContent = formatMoney(cart.total_price);
    }

    // Update shipping progress
    updateShippingProgress(cart.total_price);

    // Show/hide footer
    const footer = document.getElementById('MiniCartFooter');
    const items = document.getElementById('MiniCartItems');
    if (cart.item_count === 0) {
      footer.style.display = 'none';
      items.innerHTML = `
        <div class="mini-cart__empty">
          <p>Your cart is empty</p>
          <a href="/collections/all" class="mini-cart__continue">Continue Shopping</a>
        </div>
      `;
    } else {
      footer.style.display = '';
    }
  }

  // Update shipping progress bar
  function updateShippingProgress(totalPrice) {
    const threshold = 9900; // $99.00 in cents
    const remaining = threshold - totalPrice;
    const percent = Math.min(100, (totalPrice / threshold) * 100);
    
    const shipping = document.getElementById('MiniCartShipping');
    if (!shipping) return;

    const bar = shipping.querySelector('.mini-cart__shipping-progress');
    const text = shipping.querySelector('.mini-cart__shipping-text');
    
    bar.style.width = percent + '%';
    
    if (remaining <= 0) {
      text.className = 'mini-cart__shipping-text mini-cart__shipping-text--success';
      text.innerHTML = 'Congratulations! You qualified for <strong>Free Ground Shipping</strong>.';
    } else {
      text.className = 'mini-cart__shipping-text';
      text.innerHTML = `Add <strong>${formatMoney(remaining)}</strong> more for <strong>Free Ground Shipping</strong>.`;
    }
  }

  // Format money helper
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2);
  }

  // Expose open function for Add to Cart
  window.MiniCart = {
    open: openMiniCart,
    close: closeMiniCart,
    refresh: async function() {
      const res = await fetch('/cart.js');
      const cart = await res.json();
      updateCartUI(cart);
      // Reload items HTML
      const itemsRes = await fetch('/?section_id=mini-cart-items');
      // For simplicity, just refresh the page section
      location.reload();
    }
  };
})();
</script>
