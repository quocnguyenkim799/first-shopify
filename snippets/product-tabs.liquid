{%- comment -%}
  Product Tabs Snippet
  - Description, Features, Material, Wash tabs
  - Content from product.description + metafields
{%- endcomment -%}

<div class="product-tabs">
  <div class="tabs-nav" role="tablist">
    <button 
      type="button" 
      class="tab-btn active" 
      role="tab"
      aria-selected="true"
      aria-controls="tab-description"
      data-tab="description"
    >
      Description
    </button>
    <button 
      type="button" 
      class="tab-btn" 
      role="tab"
      aria-selected="false"
      aria-controls="tab-features"
      data-tab="features"
    >
      Features
    </button>
    <button 
      type="button" 
      class="tab-btn" 
      role="tab"
      aria-selected="false"
      aria-controls="tab-material"
      data-tab="material"
    >
      Material
    </button>
    <button 
      type="button" 
      class="tab-btn" 
      role="tab"
      aria-selected="false"
      aria-controls="tab-wash"
      data-tab="wash"
    >
      Wash
    </button>
  </div>

  <div class="tabs-content">
    <div 
      class="tab-panel active" 
      id="tab-description" 
      role="tabpanel"
      data-tab-content="description"
    >
      <div class="tab-text">
        {{ product.description }}
      </div>
    </div>

    <div 
      class="tab-panel" 
      id="tab-features" 
      role="tabpanel"
      data-tab-content="features"
      hidden
    >
      <div class="tab-text">
        {%- if product.metafields.custom.features -%}
          {{ product.metafields.custom.features | metafield_tag }}
        {%- else -%}
          <ul>
            <li>Classic four-button placket</li>
            <li>Rugged, eye-catching contrast stitching</li>
            <li>Soft-textured slub fabric</li>
            <li>Comfortable relaxed fit</li>
          </ul>
        {%- endif -%}
      </div>
    </div>

    <div 
      class="tab-panel" 
      id="tab-material" 
      role="tabpanel"
      data-tab-content="material"
      hidden
    >
      <div class="tab-text">
        {%- if product.metafields.custom.material -%}
          {{ product.metafields.custom.material | metafield_tag }}
        {%- else -%}
          <p>60% Cotton, 40% Polyester</p>
          <p>Slub jersey knit fabric for a unique texture</p>
        {%- endif -%}
      </div>
    </div>

    <div 
      class="tab-panel" 
      id="tab-wash" 
      role="tabpanel"
      data-tab-content="wash"
      hidden
    >
      <div class="tab-text">
        {%- if product.metafields.custom.wash -%}
          {{ product.metafields.custom.wash | metafield_tag }}
        {%- else -%}
          <ul>
            <li>Machine wash cold with like colors</li>
            <li>Only non-chlorine bleach when needed</li>
            <li>Tumble dry low</li>
            <li>Cool iron if needed</li>
          </ul>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const tabBtns = document.querySelectorAll('.tab-btn');
  const tabPanels = document.querySelectorAll('.tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', function() {
      const tabId = this.dataset.tab;

      tabBtns.forEach(b => {
        b.classList.remove('active');
        b.setAttribute('aria-selected', 'false');
      });

      tabPanels.forEach(p => {
        p.classList.remove('active');
        p.hidden = true;
      });

      this.classList.add('active');
      this.setAttribute('aria-selected', 'true');

      const panel = document.querySelector(`[data-tab-content="${tabId}"]`);
      if (panel) {
        panel.classList.add('active');
        panel.hidden = false;
      }
    });
  });
})();
</script>
