{{ 'announcement-bar.css' | asset_url | stylesheet_tag }}

<div class="announcement-bar">
  {%- if section.blocks.size > 1 -%}
    <button class="nav prev">
      <svg viewBox="0 0 24 24">
        <path d="M15 18L9 12L15 6"
              fill="none"
              stroke="currentColor"
              stroke-width="2"/>
      </svg>
    </button>
  {%- endif -%}
  <div class="viewport">
    {%- for block in section.blocks -%}
      <a class="item {% if forloop.first %}active{% endif %}" href="{{ block.settings.link }}">
        {{- block.settings.text -}}
      </a>
    {%- endfor -%}
  </div>
  {%- if section.blocks.size > 1 -%}
    <button class="nav next">
      <svg viewBox="0 0 24 24">
        <path d="M9 6L15 12L9 18"
              fill="none"
              stroke="currentColor"
              stroke-width="2"/>
      </svg>
    </button>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:announcement-bar.blocks.announcement.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "t:announcement-bar.blocks.announcement.settings.text.default",
          "label": "t:announcement-bar.blocks.announcement.settings.text.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:announcement-bar.blocks.announcement.settings.link.label"
        }
      ]
    }
  ]
}
{% endschema %}
