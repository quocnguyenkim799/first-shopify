<section class="section-container" style="padding-top: 0;">
  <div class="cat-banners-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="cat-banner-item" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="Shop {{ block.settings.label }}"
            width="800"
            loading="lazy"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag }}
        {%- endif -%}
        {% comment %} <div class="cat-banner-overlay"></div> {% endcomment %}
        <div class="cat-banner-label">{{ block.settings.label }}</div>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category Banners",
  "settings": [],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Banner image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Banner label",
          "default": "MEN"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Banner link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Banners",
      "blocks": [
        { "type": "banner", "settings": { "label": "MEN" } },
        { "type": "banner", "settings": { "label": "WOMEN" } },
        { "type": "banner", "settings": { "label": "CCW" } }
      ]
    }
  ]
}
{% endschema %}
