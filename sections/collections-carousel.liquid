<section class="section-container">
  {%- if section.settings.heading != blank -%}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="carousel-wrapper">
    <button class="carousel-btn left" data-carousel-btn="left" data-carousel-track="collections-track-{{ section.id }}" aria-label="Scroll left">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <div id="collections-track-{{ section.id }}" class="carousel-track">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="carousel-item" {{ block.shopify_attributes }}>
          <div class="carousel-item-inner">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 640 }}"
                alt="{{ block.settings.title }}"
                width="640"
                loading="lazy"
              >
            {%- else -%}
              {{ 'collection-1' | placeholder_svg_tag }}
            {%- endif -%}
            <div class="carousel-gradient"></div>
            <div class="carousel-item-info">
              <h3>{{ block.settings.title }}</h3>
              {%- if block.settings.subtitle != blank -%}
                <p>{{ block.settings.subtitle }}</p>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>
    <button class="carousel-btn right" data-carousel-btn="right" data-carousel-track="collections-track-{{ section.id }}" aria-label="Scroll right">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Collections Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Legendary Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Collection image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Collection title",
          "default": "Collection Name"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Collection description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collections Carousel",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Buck Commander", "subtitle": "For the love of the hunt" } },
        { "type": "collection_card", "settings": { "title": "Tough As Buck", "subtitle": "Honoring our hunting heritage" } },
        { "type": "collection_card", "settings": { "title": "Journeymen", "subtitle": "Engineered for performance" } },
        { "type": "collection_card", "settings": { "title": "Gear & Accessories", "subtitle": "Gear up for the season" } }
      ]
    }
  ]
}
{% endschema %}
