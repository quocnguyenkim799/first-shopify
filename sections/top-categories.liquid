<section class="section-container">
  {%- if section.settings.heading != blank -%}
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="categories-grid">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '#' }}" class="category-item" {{ block.shopify_attributes }}>
        <div class="category-img-wrap">
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 400 }}"
              alt="{{ block.settings.title }}"
              width="400"
              loading="lazy"
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag }}
          {%- endif -%}
        </div>
        <p class="category-name">{{ block.settings.title }}</p>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Top Categories",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Categories"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Category name",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Category link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Top Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Shirt Jackets" } },
        { "type": "category", "settings": { "title": "Flannels" } },
        { "type": "category", "settings": { "title": "Sweatshirts" } },
        { "type": "category", "settings": { "title": "Coats" } },
        { "type": "category", "settings": { "title": "Vests" } },
        { "type": "category", "settings": { "title": "Casual Shirts" } },
        { "type": "category", "settings": { "title": "Pants & Swim" } },
        { "type": "category", "settings": { "title": "Women's" } }
      ]
    }
  ]
}
{% endschema %}
